generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String
  name                String
  role                Role                 @default(GUEST)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  refereedMatches     Match[]              @relation("MatchReferee")
  scorekeptMatches    Match[]              @relation("MatchScorekeeper")
  organizationMembers OrganizationMember[]
  refreshTokens       RefreshToken[]
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  tokenHash String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Tournament {
  id             String           @id @default(cuid())
  name           String
  location       String
  startDate      DateTime
  endDate        DateTime
  status         TournamentStatus @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  organizationId String
  categories     Category[]
  tatamis        Tatami[]
  organization   Organization     @relation(fields: [organizationId], references: [id])
}

model Category {
  id           String            @id @default(cuid())
  tournamentId String
  name         String
  ageGroup     String
  gender       Gender
  discipline   Discipline
  weightMin    Float?
  weightMax    Float?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  tournament   Tournament        @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  athletes     CategoryAthlete[]
  matches      Match[]

  @@unique([tournamentId, name])
}

model ScoreEvent {
  id         String    @id @default(cuid())
  matchId    String
  athleteId  String
  corner     Corner
  type       ScoreType
  points     Int
  timestamp  DateTime  @default(now())
  exchangeId String
  wasUndone  Boolean
  athlete    Athlete   @relation(fields: [athleteId], references: [id])
  match      Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Athlete {
  id            String            @id @default(cuid())
  name          String
  state         String
  country       String            @default("IND")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  dateOfBirth   DateTime?
  photoUrl      String?
  categories    CategoryAthlete[]
  blueMatches   Match[]           @relation("BlueCorner")
  redMatches    Match[]           @relation("RedCorner")
  wonMatches    Match[]           @relation("Winner")
  penaltyEvents PenaltyEvent[]
  scoreEvents   ScoreEvent[]
}

model CategoryAthlete {
  id         String   @id @default(cuid())
  categoryId String
  athleteId  String
  seed       Int?
  athlete    Athlete  @relation(fields: [athleteId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, athleteId])
}

model Tatami {
  id           String     @id @default(cuid())
  tournamentId String
  number       Int
  name         String?
  matches      Match[]
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, number])
}

model Match {
  id                      String           @id @default(cuid())
  categoryId              String
  tatamiId                String?
  bracketSlot             Int?
  redAthleteId            String?
  blueAthleteId           String?
  status                  MatchStatus      @default(SCHEDULED)
  redScore                Int              @default(0)
  blueScore               Int              @default(0)
  senshu                  SenshuHolder     @default(NONE)
  timerSeconds            Int              @default(180)
  timeRemaining           Int              @default(180)
  winnerId                String?
  startedAt               DateTime?
  completedAt             DateTime?
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  resultType              MatchResultType?
  nextMatchId             String?
  nextMatchSlot           String?
  senshuLocked            Boolean          @default(false)
  senshuScoreEventId      String?
  last15SecondsSenshuLost Boolean          @default(false)
  pool                    Int?
  refereeId               String?
  scorekeeperId           String?
  round                   MatchRound
  nextCorner              Corner?
  loserNextMatchId        String?
  loserNextCorner         Corner?
  kataScores              KataScore[]
  blueAthlete             Athlete?         @relation("BlueCorner", fields: [blueAthleteId], references: [id])
  category                Category         @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  redAthlete              Athlete?         @relation("RedCorner", fields: [redAthleteId], references: [id])
  referee                 User?            @relation("MatchReferee", fields: [refereeId], references: [id])
  scorekeeper             User?            @relation("MatchScorekeeper", fields: [scorekeeperId], references: [id])
  tatami                  Tatami?          @relation(fields: [tatamiId], references: [id])
  winner                  Athlete?         @relation("Winner", fields: [winnerId], references: [id])
  penaltyEvents           PenaltyEvent[]
  scoreEvents             ScoreEvent[]
}

model PenaltyEvent {
  id        String      @id @default(cuid())
  matchId   String
  athleteId String
  corner    Corner
  type      PenaltyType
  timestamp DateTime    @default(now())
  athlete   Athlete     @relation(fields: [athleteId], references: [id])
  match     Match       @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model Organization {
  id          String               @id @default(cuid())
  name        String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  members     OrganizationMember[]
  tournaments Tournament[]

  @@map("organizations")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String
  userId         String
  role           Role
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model KataScore {
  id             String   @id @default(cuid())
  matchId        String
  athleteId      String
  judgeId        String
  technicalScore Float?
  athleticScore  Float?
  totalScore     Float
  createdAt      DateTime @default(now())
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model TournamentSettings {
  id                   String   @id @default("default")
  mercyRuleGap         Int      @default(8)
  matchDurationSeconds Int      @default(180)
  senshuEnabled        Boolean  @default(true)
  updatedAt            DateTime @updatedAt
}

enum Role {
  GUEST
  ATHLETE
  SCOREKEEPER
  REFEREE
  ORGANIZER
  ADMIN
  SUPER_ADMIN
}

enum TournamentStatus {
  DRAFT
  ONGOING
  COMPLETED
  CANCELLED
}

enum Discipline {
  KATA
  KUMITE
  TEAM_KATA
  TEAM_KUMITE
}

enum Gender {
  MALE
  FEMALE
  MIXED
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum SenshuHolder {
  NONE
  RED
  BLUE
}

enum MatchResultType {
  POINT_GAP
  TIME
  HANSOKU
  KIKEN
  HANTEI
  SENSHU
}

enum MatchRound {
  ROUND_1
  ROUND_2
  ROUND_3
  ROUND_OF_32
  ROUND_OF_16
  QUARTER_FINAL
  QUARTERFINAL
  SEMI_FINAL
  SEMIFINAL
  FINAL
  FINAL_MATCH
  REPECHAGE
  BRONZE
  BRONZE_MEDAL     // ← This was missing in some places
}

enum ScoreType {
  YUKO
  WAZA_ARI
  IPPON
}

enum Corner {
  RED
  BLUE
}

enum PenaltyType {
  CHUI
  HANSOKU_CHUI
  HANSOKU
}
